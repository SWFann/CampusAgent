# ============================================
# CampusAgent Environment Variables Template
# ============================================
# Copy this file to .env and fill in the values
# DO NOT commit .env to version control

# ---------------------------
# Application
# ---------------------------
APP_ENV=development
APP_NAME=CampusAgent API
APP_VERSION=0.1.0
DEBUG=false

# ---------------------------
# Database
# ---------------------------
# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/campus_agent

# ---------------------------
# Redis
# ---------------------------
# Redis connection string
# Format: redis://:PASSWORD@HOST:PORT/DB
REDIS_URL=redis://localhost:6379/0

# ---------------------------
# Security
# ---------------------------
# JWT Secret Key (CHANGE THIS IN PRODUCTION!)
# Generate with: openssl rand -hex 32
APP_SECRET=dev-secret-key-change-in-production

# Field Encryption Key (for encrypting sensitive fields)
# Generate with: openssl rand -hex 32
FIELD_ENCRYPTION_KEY=dev-encryption-key-change-in-production

# Access Token expiration (minutes)
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Refresh Token expiration (days)
REFRESH_TOKEN_EXPIRE_DAYS=7

# ---------------------------
# API Configuration
# ---------------------------
API_V1_PREFIX=/api/v1

# ---------------------------
# Frontend (Next.js)
# ---------------------------
# Next.js public API URL
NEXT_PUBLIC_API_URL=http://localhost:8000

# ---------------------------
# Model Gateway
# ---------------------------
# Model Gateway Base URL
MODEL_GATEWAY_BASE_URL=http://localhost:8001

# Model Gateway API Key
MODEL_GATEWAY_API_KEY=

# ---------------------------
# Logging
# ---------------------------
LOG_LEVEL=INFO
LOG_PROMPT_CONTENT=false

# ---------------------------
# Feature Flags
# ---------------------------
# Enable external model (disabled by default)
ENABLE_EXTERNAL_MODEL=false

# Private scene TTL (hours)
PRIVATE_SCENE_TTL_HOURS=24

# ---------------------------
# Testing
# ---------------------------
# Test environment variables (overridden by test runner)
APP_ENV=test
