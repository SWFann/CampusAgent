# ============================================
# CampusAgent Environment Variables Template
# ============================================
# Copy this file to .env and fill in the values
# DO NOT commit .env to version control

# ---------------------------
# Application
# ---------------------------
APP_ENV=development
APP_NAME=CampusAgent API
APP_VERSION=0.1.0
APP_DEBUG=false

# ---------------------------
# Database
# ---------------------------
# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# Local dev (non-Docker):   postgresql://postgres:postgres@localhost:5432/campus_agent
# Docker Compose:           postgresql://postgres:postgres@postgres:5432/campus_agent
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/campus_agent

# Database connection pool settings
# (Applied to PostgreSQL; SQLite in tests uses StaticPool)
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT_SECONDS=30
DB_POOL_RECYCLE_SECONDS=1800
# Echo SQL statements to logs (must be false in production)
DB_ECHO_SQL=false

# ---------------------------
# Redis
# ---------------------------
# Redis connection string
# Format: redis://:PASSWORD@HOST:PORT/DB
# Local dev (non-Docker):   redis://localhost:6379/0
# Docker Compose:           redis://redis:6379/0
# Note: Redis runs without password in local development only.
#       Production must require authentication.
REDIS_URL=redis://localhost:6379/0

# Redis namespace prefix for keys
REDIS_NAMESPACE=campus_agent

# Redis socket timeout (seconds)
REDIS_SOCKET_TIMEOUT_SECONDS=5

# Redis connect timeout (seconds)
REDIS_CONNECT_TIMEOUT_SECONDS=5

# Default cache TTL (seconds)
DEFAULT_CACHE_TTL_SECONDS=300

# ---------------------------
# Security
# ---------------------------
# JWT Secret Key (CHANGE THIS IN PRODUCTION!)
# Generate with: openssl rand -hex 32
APP_SECRET=dev-secret-key-change-in-production

# Field Encryption Key (for encrypting sensitive fields)
# Generate with: openssl rand -hex 32
FIELD_ENCRYPTION_KEY=dev-encryption-key-change-in-production

# Access Token expiration (minutes)
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Refresh Token expiration (days)
REFRESH_TOKEN_EXPIRE_DAYS=7

# ---------------------------
# API Configuration
# ---------------------------
API_V1_PREFIX=/api/v1

# ---------------------------
# Frontend (Next.js)
# ---------------------------
# Next.js public API URL
NEXT_PUBLIC_API_URL=http://localhost:8000

# Public demo / production URLs
# Example:
# PUBLIC_WEB_HOST=campus.example.com
# PUBLIC_API_HOST=api-campus.example.com
# PUBLIC_WEB_URL=https://campus.example.com
# PUBLIC_API_URL=https://api-campus.example.com
PUBLIC_WEB_HOST=
PUBLIC_API_HOST=
PUBLIC_WEB_URL=
PUBLIC_API_URL=

# Optional Let's Encrypt account email for Caddy
ACME_EMAIL=

# ---------------------------
# Model Gateway
# ---------------------------
# Model Gateway Base URL
# StepFun China platform:   https://api.stepfun.com/v1
# Local mock (non-Docker):  http://localhost:8001
# Docker Compose mock:      http://mock-model:8001
# Campus k8s vLLM/llama.cpp nodes can also be used when they expose an
# OpenAI-compatible /v1/chat/completions endpoint.
MODEL_GATEWAY_BASE_URL=https://api.stepfun.com/v1
MODEL_GATEWAY_MODEL=step-3.5-flash
MODEL_GATEWAY_TIMEOUT_MS=60000
MODEL_GATEWAY_IS_EXTERNAL=true

# Model Gateway API Key. Never commit a real key.
MODEL_GATEWAY_API_KEY=

# ---------------------------
# Logging
# ---------------------------
LOG_LEVEL=INFO
LOG_PROMPT_CONTENT=false

# ---------------------------
# Feature Flags
# ---------------------------
# Enable external model (disabled by default)
ENABLE_EXTERNAL_MODEL=false

# Private scene TTL (hours)
PRIVATE_SCENE_TTL_HOURS=24

# ---------------------------
# Testing
# ---------------------------
# Test runner overrides APP_ENV=test in apps/api/tests/conftest.py.
# Do not set APP_ENV=test in the default development .env template.
